# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vit_db
# Note: Replit-managed Postgres usually handles SSL automatically.
# Avoid adding ?sslmode=require or ?sslmode=disable to DATABASE_URL when using asyncpg.

# API Security
API_KEY=your_super_secret_api_key_here_change_this

# ML Service
ML_SERVICE_URL=http://localhost:8001

# Redis (optional)
REDIS_URL=redis://localhost:6379

# External APIs
ODDS_API_KEY=your_odds_api_key
FOOTBALL_DATA_KEY=your_football_data_key

# Betting Limits
MAX_STAKE_PERCENT=0.05
MIN_EDGE_THRESHOLD=0.02
MAX_BANKROLL_PERCENT=0.10

# Alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Logging
LOG_LEVEL=INFO